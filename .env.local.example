# ============================================================
# CARLO ETHICS.AI — HEALTH CHATBOT CONFIG
# ============================================================
# Step 1: Create a new project on Carlo dashboard (carlo.algorethics.ai)
# Step 2: Copy your API key and Project ID into the fields below
# Step 3: Add your Anthropic API key
# Step 4: Add these same keys to Vercel Environment Variables
# ============================================================

# Anthropic (AI responses)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Carlo Ethics.ai (compliance layer)
# Get these from: carlo.algorethics.ai > Projects > Your Health Project > Code Setup
CARLO_API_KEY=your_carlo_api_key_here
CARLO_PROJECT_ID=your_carlo_project_id_here
CARLO_ENDPOINT=https://carlo.algorethics.ai/api/dashboard/analyze

# App config
NEXT_PUBLIC_APP_NAME=Health Assistant
